{
  "manifest_version": 3,
  "name": "Boss Spider",
  "version": "0.1.0",
  "description": "BOSS直聘公司端候选人筛选与收藏助手。",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://*.zhipin.com/*",
    "http://localhost/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_title": "Boss Spider",
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html",
  "content_scripts": [
    {
      "matches": ["https://*.zhipin.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
